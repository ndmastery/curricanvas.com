{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "CurriCanvas",
  "short_name": "CurriCanvas",
  "start_url": "/",
  "scope": "/",
  "id": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#FCFAF7",
  "theme_color": "#B85C38",
  "icons": [
    {
      "src": "curricanvas-logo.png",
      "type": "image/png",
